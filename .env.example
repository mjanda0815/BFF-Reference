# ===== Keycloak =====
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=bff-demo
KEYCLOAK_CLIENT_ID=bff-client
KEYCLOAK_CLIENT_SECRET=bff-client-secret
KEYCLOAK_ISSUER_URI=http://keycloak:8080/realms/bff-demo
# Public (browser-facing) Keycloak URL. This is what the browser sees when it is redirected
# to the Keycloak login page. The `iss` claim in the id_token Keycloak issues matches this
# URL, so the BFF and the downstream services validate tokens against it.
KEYCLOAK_PUBLIC_ISSUER_URI=http://localhost:8080/realms/bff-demo
KEYCLOAK_JWK_SET_URI=http://keycloak:8080/realms/bff-demo/protocol/openid-connect/certs

# ===== Redis =====
REDIS_HOST=redis
REDIS_PORT=6379

# ===== BFF =====
BFF_PORT=8090
BFF_FRONTEND_ORIGIN=http://localhost
BFF_SESSION_TIMEOUT_SECONDS=1800
BFF_COOKIE_SECURE=false

# ===== Backend Services (intern, nur fürs BFF) =====
USER_SERVICE_URL=http://user-service:8081
NOTIFICATION_SERVICE_URL=http://notification-service:8082
ACTIVITY_SERVICE_URL=http://activity-service:8083

# ===== Frontend =====
FRONTEND_PORT=80
